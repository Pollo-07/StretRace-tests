{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node", "jest"],
    "typeRoots": [
      "./node_modules/@types",
      "../StretRace/src/types"
